# AdsVerse WhatsApp Bot - Environment Configuration

# WhatsApp Session Name (Internal)
SESSION_ID=adsverse-bot

# Gemini API Key (from Google AI Studio)
GEMINI_API_KEY=

# Admin WhatsApp number (without +91, without @c.us)
# Example: +919876543210
ADMIN_NUMBER=

# Bot pause state (bot reads this at runtime)
BOT_PAUSED=false

# Notification: Notify admin when new lead is closed?
NOTIFY_ADMIN_ON_LEAD=true

# Human flag: Notify admin when bot flags a user?
NOTIFY_ADMIN_ON_FLAG=true

# Business Phone (Displayed to customers)
BUSINESS_PHONE=+919685123339

# Business Email
BUSINESS_EMAIL=hello@adsverse.in
